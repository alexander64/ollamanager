<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OllamaManager.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon ToolTipText="Ollama Manager"
                      Icon="avares://OllamaManager/Assets/tray.png">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Mostra / Nascondi" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Esci" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
